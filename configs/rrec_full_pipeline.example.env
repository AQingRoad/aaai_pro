# Example config for scripts/pipelines/run_rrec_full_training_pipeline.sh
# Copy this file on the training server and edit paths/API keys before running.

export ROOT=/root/autodl-tmp/rec/aaai_pro
export RREC_DATA_ROOT=/root/autodl-tmp/rec/RRec_official/data
export VENV=/root/autodl-tmp/rec/ms-swift-312-cu124-venv

export CATEGORY=CDs_and_Vinyl
export RUN_NAME=cds_qwen3_4b_full

export MODEL=/root/autodl-tmp/modelscope_cache/models/Qwen/Qwen3-4B
export MODEL_TYPE=qwen3
export BASE_EMBEDDING_MODEL=/root/autodl-tmp/modelscope_cache/models/Qwen/Qwen3-Embedding-0.6B

# API key for GLM CodePlan candidate generation and rubric scoring.
# Preferred: write the real key into configs/rrec_full_pipeline.local.env or
# configs/glm_codeplan.env, both are local machine configs.
export BIGMODEL_API_KEY=

# End-to-end stage switches. Set a stage to 0 to skip it, or auto to reuse
# existing output files and run only missing stages.
export RUN_PREPARE_EXAMPLES=auto
export RUN_EMBEDDER_DATA=auto
export RUN_EMBEDDER_TRAIN=1
export RUN_COT_GENERATE=auto
export RUN_RUBRIC_SCORE=auto
export RUN_MERGE=auto
export RUN_GAIN=auto
export RUN_SELECT=auto
export RUN_DATASETS=auto
export RUN_SFT=1
export RUN_SFT_MERGE=0
export RUN_GRPO=1
export RUN_EVAL=0

# Full-parameter training is the default. To use LoRA instead:
#   export SFT_TRAIN_TYPE=lora
#   export GRPO_TRAIN_TYPE=lora
export SFT_TRAIN_TYPE=full
export GRPO_TRAIN_TYPE=full

# Dataset/candidate sizes. Keep MAX_EXAMPLES=0 for full split.
export MAX_EXAMPLES=0
export MAX_HISTORY_ITEMS=20
export NUM_CANDIDATES=4
export COT_MAX_WORKERS=1

# Phase-0 embedding training.
export EMBEDDER_CATEGORIES="CDs_and_Vinyl"
export EMBEDDER_MAX_EXAMPLES_PER_CATEGORY=0
export EMBEDDER_MAX_LENGTH=2048
export EMBEDDER_BATCH_SIZE=16
export EMBEDDER_GRAD_ACCUM=1
export EMBEDDER_EPOCHS=1
export EMBEDDER_MAX_STEPS=-1
export EMBEDDER_LR=1e-5

# SFT full training. Adjust batch/accum for the new server GPU memory.
export SFT_CUDA_VISIBLE_DEVICES=0
export SFT_NPROC_PER_NODE=1
export SFT_MASTER_PORT=29500
export SFT_BATCH_SIZE=1
export SFT_GRAD_ACCUM=8
export SFT_MAX_LENGTH=4096
export SFT_LEARNING_RATE=1e-5
export SFT_NUM_TRAIN_EPOCHS=1
export SFT_MAX_STEPS=-1
export SFT_SAVE_STEPS=200

# GRPO full training. With a second GPU, enable vLLM server below.
export GRPO_CUDA_VISIBLE_DEVICES=0
export GRPO_NPROC_PER_NODE=1
export GRPO_MASTER_PORT=29501
export GRPO_BATCH_SIZE=1
export GRPO_GRAD_ACCUM=2
export GRPO_MAX_LENGTH=4096
export GRPO_MAX_COMPLETION_LENGTH=2048
export GRPO_LEARNING_RATE=1e-6
export GRPO_MAX_STEPS=20
export GRPO_NUM_GENERATIONS=2

# Multi-GPU examples:
#   4 GPUs total, train on GPU0-1, vLLM on GPU2-3:
#     SFT_CUDA_VISIBLE_DEVICES=0,1
#     SFT_NPROC_PER_NODE=2
#     GRPO_CUDA_VISIBLE_DEVICES=0,1
#     GRPO_NPROC_PER_NODE=2
#     VLLM_CUDA_VISIBLE_DEVICES=2,3
#     VLLM_TENSOR_PARALLEL_SIZE=2
#
# Default below uses GPU1 as vLLM rollout server and GPU0 as trainer.
export RUN_VLLM_SERVER=1
export GRPO_CUDA_VISIBLE_DEVICES=0
export VLLM_CUDA_VISIBLE_DEVICES=1
export VLLM_SERVER_PORT=8001
export VLLM_GPU_MEMORY_UTILIZATION=0.8
export VLLM_MAX_MODEL_LEN=6144
export VLLM_TENSOR_PARALLEL_SIZE=1
export VLLM_PIPELINE_PARALLEL_SIZE=1

# Direct GLM CodePlan scoring with short JSON output and no thinking tokens.
export COT_GENERATION_API_PROVIDER=glm_codeplan
export COT_GENERATION_API_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
export COT_GENERATION_API_MODEL=glm-5.2
export COT_GENERATION_API_THINKING=enabled
export COT_GENERATION_API_REASONING_EFFORT=medium

export RUBRIC_JUDGE_PROVIDER=openai_compatible
export RUBRIC_JUDGE_API_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
export RUBRIC_JUDGE_API_MODEL=glm-5.2
export RUBRIC_JUDGE_API_MAX_TOKENS=128
export RUBRIC_JUDGE_API_THINKING=disabled
export RUBRIC_JUDGE_WORKERS=1
export RUBRIC_JUDGE_MIN_INTERVAL=0

export RUBRIC_REWARD_API_PROVIDER=openai_compatible
export RUBRIC_REWARD_API_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
export RUBRIC_REWARD_API_MODEL=glm-5.2
export RUBRIC_REWARD_API_MAX_TOKENS=128
export RUBRIC_REWARD_API_THINKING=disabled
export RUBRIC_REWARD_API_FALLBACK=none
