# Training config for scripts/run_rrec_full_training_pipeline.sh.
# Use this on a new server after downloading/copying prebuilt JSONL datasets.
# It skips CoT/rubric/data construction, trains the embedding model from the
# phase0 dataset, then runs SFT and GRPO.

export ROOT=/root/autodl-tmp/rec/aaai_pro
export VENV=/root/autodl-tmp/rec/ms-swift-312-cu124-venv

export CATEGORY=CDs_and_Vinyl
export RUN_NAME=cds_qwen3_4b_train_only

export MODEL=/root/autodl-tmp/modelscope_cache/models/Qwen/Qwen3-4B
export MODEL_TYPE=qwen3

export BASE_EMBEDDING_MODEL=/root/autodl-tmp/modelscope_cache/models/Qwen/Qwen3-Embedding-0.6B

# Prebuilt datasets downloaded from ModelScope or copied from local. The script
# reads these files directly and does not rebuild them.
export EMBEDDER_DATASET=/root/autodl-tmp/rec/aaai_pro/github_artifacts/CDs_and_Vinyl/phase0/phase0_embedder_rrec_amazon_cds_and_vinyl_train.jsonl
export SFT_DATASET=/root/autodl-tmp/rec/aaai_pro/github_artifacts/CDs_and_Vinyl/sft/sft_rrec_amazon_cds_and_vinyl_deepseek_v4_pro_cds_embedder_partial.jsonl
export GRPO_DATASET=/root/autodl-tmp/rec/aaai_pro/github_artifacts/CDs_and_Vinyl/grpo/grpo_rrec_amazon_cds_and_vinyl_deepseek_v4_pro_cds_embedder_disjoint_full.jsonl

# API key. You can also put the real key in configs/glm_codeplan.env.
export BIGMODEL_API_KEY=replace_with_real_key

# Disable data construction stages. Keep RUN_EMBEDDER_TRAIN=1 so the new
# server trains its own CDs embedding checkpoint before SFT/GRPO.
export TRAIN_ONLY=1
export RUN_EMBEDDER_TRAIN=1
export RUN_SFT=1
export RUN_GRPO=1
export RUN_EVAL=0

# Full-parameter training by default. Change to lora only if needed.
export SFT_TRAIN_TYPE=full
export GRPO_TRAIN_TYPE=full

# Multi-GPU training settings. Adjust these to match the new server.
export EMBEDDER_CUDA_VISIBLE_DEVICES=0

export SFT_CUDA_VISIBLE_DEVICES=0,1
export SFT_NPROC_PER_NODE=2
export SFT_MASTER_PORT=29500

export GRPO_CUDA_VISIBLE_DEVICES=0,1
export GRPO_NPROC_PER_NODE=2
export GRPO_MASTER_PORT=29501

# vLLM rollout server can use a separate GPU group.
export RUN_VLLM_SERVER=1
export VLLM_CUDA_VISIBLE_DEVICES=2,3
export VLLM_TENSOR_PARALLEL_SIZE=2
export VLLM_PIPELINE_PARALLEL_SIZE=1
export VLLM_SERVER_PORT=8001
export VLLM_GPU_MEMORY_UTILIZATION=0.8
export VLLM_MAX_MODEL_LEN=6144

# Embedding training hyperparameters.
export EMBEDDER_OUT=/root/autodl-tmp/rec/aaai_pro/checkpoints/rrec_amazon_CDs_and_Vinyl/qwen3_embedding_cds_train_only
export EMBEDDER_BATCH_SIZE=128
export EMBEDDER_GRAD_ACCUM=1
export EMBEDDER_MAX_LENGTH=2048
export EMBEDDER_EPOCHS=1
export EMBEDDER_MAX_STEPS=-1
export EMBEDDER_LR=1e-5
export EMBEDDER_SAVE_STEPS=0

# SFT hyperparameters.
export SFT_BATCH_SIZE=1
export SFT_GRAD_ACCUM=8
export SFT_MAX_LENGTH=4096
export SFT_LEARNING_RATE=1e-5
export SFT_NUM_TRAIN_EPOCHS=1
export SFT_MAX_STEPS=-1
export SFT_SAVE_STEPS=200

# GRPO hyperparameters.
export GRPO_BATCH_SIZE=1
export GRPO_GRAD_ACCUM=2
export GRPO_MAX_LENGTH=4096
export GRPO_MAX_COMPLETION_LENGTH=2048
export GRPO_LEARNING_RATE=1e-6
export GRPO_MAX_STEPS=20
export GRPO_NUM_GENERATIONS=2

# Direct GLM CodePlan reward scoring.
export RUBRIC_REWARD_API_PROVIDER=openai_compatible
export RUBRIC_REWARD_API_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
export RUBRIC_REWARD_API_MODEL=glm-5.2
export RUBRIC_REWARD_API_MAX_TOKENS=128
export RUBRIC_REWARD_API_THINKING=disabled
export RUBRIC_REWARD_API_FALLBACK=none
