# Copy this file to configs/rrec_full_pipeline.local.env and write the real key.
# configs/*.local.env is ignored by git.

_config_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$_config_dir/rrec_full_pipeline.example.env"

export BIGMODEL_API_KEY=replace_with_real_key

# Optional multi-GPU override examples:
# export SFT_CUDA_VISIBLE_DEVICES=0,1
# export SFT_NPROC_PER_NODE=2
# export GRPO_CUDA_VISIBLE_DEVICES=0,1
# export GRPO_NPROC_PER_NODE=2
# export VLLM_CUDA_VISIBLE_DEVICES=2,3
# export VLLM_TENSOR_PARALLEL_SIZE=2
