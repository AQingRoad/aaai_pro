# Tidal server config for scripts/run_rrec_full_training_pipeline.sh.
# This config uses GitHub-committed CDs JSONL artifacts, trains the CDs
# embedding checkpoint on this server, then runs SFT and GRPO.

export ROOT=/mnt/tidal-sh01/usr/xiayu6/xiayu/aaai_pro
export VENV=${VENV:-/root/miniconda3/envs/swift}

export CATEGORY=CDs_and_Vinyl
export RUN_NAME=cds_qwen3_4b_tidal

export MODEL=/mnt/tidal-sh01/usr/xiayu6/xiayu/checkpoint/Qwen3/4B
export MODEL_TYPE=qwen3

export BASE_EMBEDDING_MODEL=/mnt/tidal-sh01/usr/xiayu6/xiayu/checkpoint/Qwen3_embedding/0.6B

# JSONL artifacts are committed to this GitHub repo.
export EMBEDDER_DATASET=$ROOT/github_artifacts/CDs_and_Vinyl/phase0/phase0_embedder_rrec_amazon_cds_and_vinyl_train.jsonl
export SFT_DATASET=$ROOT/github_artifacts/CDs_and_Vinyl/sft/sft_rrec_amazon_cds_and_vinyl_deepseek_v4_pro_cds_embedder_partial.jsonl
export GRPO_DATASET=$ROOT/github_artifacts/CDs_and_Vinyl/grpo/grpo_rrec_amazon_cds_and_vinyl_deepseek_v4_pro_cds_embedder_disjoint_full.jsonl

# The runner skips CoT/rubric/merge/gain/select/dataset construction, keeps
# embedding training enabled, then runs SFT/GRPO.
export TRAIN_ONLY=1
export RUN_EMBEDDER_TRAIN=1
export RUN_SFT=1
export RUN_GRPO=1
export RUN_EVAL=0

# Full-parameter training by default. Set these to lora only if needed.
export SFT_TRAIN_TYPE=full
export GRPO_TRAIN_TYPE=full

# Adjust GPU groups to match the new machine.
export EMBEDDER_CUDA_VISIBLE_DEVICES=0

export SFT_CUDA_VISIBLE_DEVICES=0,1
export SFT_NPROC_PER_NODE=2
export SFT_MASTER_PORT=29500

export GRPO_CUDA_VISIBLE_DEVICES=0,1
export GRPO_NPROC_PER_NODE=2
export GRPO_MASTER_PORT=29501

# vLLM rollout server can use a separate GPU group.
export RUN_VLLM_SERVER=1
export VLLM_CUDA_VISIBLE_DEVICES=2,3
export VLLM_TENSOR_PARALLEL_SIZE=2
export VLLM_PIPELINE_PARALLEL_SIZE=1
export VLLM_SERVER_PORT=8001
export VLLM_GPU_MEMORY_UTILIZATION=0.8
export VLLM_MAX_MODEL_LEN=6144

# Embedding training hyperparameters.
export EMBEDDER_OUT=$ROOT/checkpoints/rrec_amazon_CDs_and_Vinyl/qwen3_embedding_cds_tidal
export EMBEDDER_BATCH_SIZE=128
export EMBEDDER_GRAD_ACCUM=1
export EMBEDDER_MAX_LENGTH=2048
export EMBEDDER_EPOCHS=1
export EMBEDDER_MAX_STEPS=-1
export EMBEDDER_LR=1e-5
export EMBEDDER_SAVE_STEPS=0

# SFT hyperparameters.
export SFT_BATCH_SIZE=1
export SFT_GRAD_ACCUM=8
export SFT_MAX_LENGTH=4096
export SFT_LEARNING_RATE=1e-5
export SFT_NUM_TRAIN_EPOCHS=1
export SFT_MAX_STEPS=-1
export SFT_SAVE_STEPS=200

# GRPO hyperparameters.
export GRPO_BATCH_SIZE=1
export GRPO_GRAD_ACCUM=2
export GRPO_MAX_LENGTH=4096
export GRPO_MAX_COMPLETION_LENGTH=2048
export GRPO_LEARNING_RATE=1e-6
export GRPO_MAX_STEPS=20
export GRPO_NUM_GENERATIONS=2

# Direct GLM CodePlan reward scoring. Put the real key in
# $ROOT/configs/glm_codeplan.env on the server.
export RUBRIC_REWARD_API_PROVIDER=openai_compatible
export RUBRIC_REWARD_API_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
export RUBRIC_REWARD_API_MODEL=glm-5.2
export RUBRIC_REWARD_API_MAX_TOKENS=128
export RUBRIC_REWARD_API_THINKING=disabled
export RUBRIC_REWARD_API_FALLBACK=none
